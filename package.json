{
  "name": "luma",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev --port=3000 --hostname=0.0.0.0",
    "build": "next build",
    "start": "next start --port=3000 --hostname=0.0.0.0",
    "clean": "rm -rf .next out dist",
    "lint": "node -e \"const { execSync } = require('child_process'); execSync('npx eslint .', { stdio: 'inherit' });\"",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.17",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2"
  }
}
